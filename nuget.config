<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Local feed populated by scripts/pack-core.sh.
      Pack before running Dmon.cs: bash scripts/pack-core.sh
    -->
    <add key="local-dmon-feed" value=".pack-out" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
