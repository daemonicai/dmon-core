<Project>

  <!-- ====================================================================
       Shared build properties for all projects in the solution.
       IsPackable defaults to false; the five distribution projects opt in.
       ==================================================================== -->

  <PropertyGroup>
    <Authors>Emmz Rendle</Authors>
    <Company>daemonicai</Company>
    <Product>dmon</Product>
    <RepositoryUrl>https://github.com/daemonicai/dmon-core</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/daemonicai/dmon-core</PackageProjectUrl>
    <PackageLicenseExpression>MPL-2.0</PackageLicenseExpression>

    <!-- Symbol packages -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- Deterministic / reproducible builds -->
    <Deterministic>true</Deterministic>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>

    <!-- Non-packable by default; distribution projects override this to true -->
    <IsPackable>false</IsPackable>

    <!-- Protocol-keyed by default: all packable distribution packages must have Major.Minor == ProtocolVersion.Current.
         App-artifact dotnet tools (e.g. Dmon.Network) set this to false per ADR-024 (independently versioned). -->
    <IsProtocolKeyedPackage>true</IsProtocolKeyedPackage>

    <!-- SQLitePCLRaw.lib.e_sqlite3 2.1.11 (transitive via Microsoft.Data.Sqlite) carries
         GHSA-2m69-gcr7-jv3q (high). Suppressed repo-wide until Microsoft.Data.Sqlite ships
         a version that pulls in SQLitePCLRaw >= 2.1.12 where the advisory is fixed. -->
    <NoWarn>$(NoWarn);NU1903</NoWarn>
  </PropertyGroup>

  <!-- CI: deterministic path-mapping so build paths don't embed the CI agent's home dir -->
  <PropertyGroup Condition="'$(GITHUB_ACTIONS)' == 'true' Or '$(CI)' == 'true'">
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <!-- SourceLink and MinVer are declared as GlobalPackageReference in Directory.Packages.props
       (CPM-idiomatic; implies PrivateAssets="all" and applies to every project). -->

  <!-- Version floor: untagged builds produce 0.2.0-alpha.0 (matching ProtocolVersion.Current = "0.2") -->
  <PropertyGroup>
    <MinVerMinimumMajorMinor>0.2</MinVerMinimumMajorMinor>
  </PropertyGroup>

  <!-- ====================================================================
       Version-skew guard (task 4.5 / ADR-011 D8)

       Reads ProtocolVersion.Current from ProtocolVersion.cs using regex so
       the guard never hard-codes the value — there is exactly one authored
       protocol version in the codebase.

       Runs AfterTargets="MinVer" so $(MinVerMajor)/$(MinVerMinor) are set,
       and only for packable projects (IsPackable == true).
       ==================================================================== -->

  <PropertyGroup>
    <!-- Path to the C# file that holds the single authored protocol version -->
    <_ProtocolVersionFile>$(MSBuildThisFileDirectory)core/Dmon.Protocol/ProtocolVersion.cs</_ProtocolVersionFile>
  </PropertyGroup>

  <Target Name="CheckProtocolVersionSkew"
          AfterTargets="MinVer"
          Condition="'$(IsPackable)' == 'true' and '$(IsProtocolKeyedPackage)' != 'false'">

    <!-- Read the file lines into an item list -->
    <ReadLinesFromFile File="$(_ProtocolVersionFile)">
      <Output TaskParameter="Lines" ItemName="_ProtocolVersionLines" />
    </ReadLinesFromFile>

    <!-- Extract the "x.y" literal from:  public const string Current = "x.y";
         NOTE: the regex requires Current's declaration to be on a single line.
         Do not reformat that const to span multiple lines or this guard will fail. -->
    <PropertyGroup>
      <_ProtocolVersionRaw>@(_ProtocolVersionLines)</_ProtocolVersionRaw>
      <!-- Match: Current = "0.1" — capture the quoted value -->
      <_ProtocolMajorMinor>$([System.Text.RegularExpressions.Regex]::Match(
          '$(_ProtocolVersionRaw)',
          'Current\s*=\s*"(\d+\.\d+)"').Groups[1].Value)</_ProtocolMajorMinor>
    </PropertyGroup>

    <Error
      Condition="'$(_ProtocolMajorMinor)' == ''"
      Text="Version-skew guard: could not parse ProtocolVersion.Current from $(_ProtocolVersionFile). Check the file syntax." />

    <PropertyGroup>
      <_PackedMajorMinor>$(MinVerMajor).$(MinVerMinor)</_PackedMajorMinor>
    </PropertyGroup>

    <Error
      Condition="'$(_PackedMajorMinor)' != '$(_ProtocolMajorMinor)'"
      Text="Version-skew guard: package version Major.Minor is $(_PackedMajorMinor) but ProtocolVersion.Current is $(_ProtocolMajorMinor). Tag this release with a tag whose Major.Minor equals the protocol version." />

  </Target>

</Project>
