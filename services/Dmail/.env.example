# Copy this file to .env and fill in your values:  cp .env.example .env
# docker-compose.yml reads these automatically. .env is gitignored — never commit secrets.

# --- Gmail OAuth2 (required to add Gmail accounts) ---
# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID.
# Register redirect URI: http://localhost:8080/api/auth/google/callback
AIM_GOOGLE_CLIENT_ID=
AIM_GOOGLE_CLIENT_SECRET=

# --- API key (optional) ---
# Leave blank to have one auto-generated on first run (printed once in the logs).
AIM_API_KEY=

# --- Host port (optional, default 8080) ---
# Host-side port mapped to the container's 8080. Change if 8080 is taken.
AIM_PORT=8080

# --- Backfill window in months (optional, default 1) ---
AIM_BACKFILL_MONTHS=1
