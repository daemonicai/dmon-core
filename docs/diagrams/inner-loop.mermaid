%% dmoncore inner loop — session vs context window vs stateless runtime
flowchart TB
    subgraph DURABLE["Durable layer — survives process restart"]
        STORE[("ISessionStore<br/>on-disk session log")]
    end

    subgraph MEM["In-memory layer — TurnHandler (ephemeral)"]
        HIST["_history : List&lt;ChatMessage&gt;<br/>the context window content"]

        subgraph OUTER["RunTurnAsync — OUTER loop (steer / follow-up only)"]
            BUILD["Rebuild IChatClient pipeline<br/>(per-turn, so provider/model<br/>switches take effect)"]
            STREAM["pipeline.GetStreamingResponseAsync(_history)<br/>— sends the WHOLE window"]
            RECON["Reconstruct assistant + tool<br/>messages from streamed updates<br/>→ append to _history"]
            DECIDE{"pending steer<br/>or follow-up?"}
        end
    end

    subgraph PIPE["IChatClient pipeline (outermost → innermost)"]
        PERM["PermissionGateChatClient"]
        FIC["FunctionInvokingChatClient"]
        RETRY["RetryingChatClient"]
        MW["user middleware"]
        PROV["provider client"]

        subgraph INNER["INNER loop — runs INSIDE FunctionInvokingChatClient"]
            TOOLCALL{"model emitted<br/>a tool call?"}
            INVOKE["invoke AIFunction locally<br/>append result, re-call provider"]
        end
    end

    subgraph RUNTIME["Stateless per-call — model runtime"]
        MODEL["Ollama / Anthropic / OpenAI<br/>messages in → tokens out<br/>(keeps NOTHING between calls)"]
    end

    %% seeding / persistence bridge
    STORE -. "SeedHistoryFromSessionAsync<br/>(on resume, applies compaction)" .-> HIST
    HIST -. "PersistNewHistoryEntriesAsync<br/>(after each turn, new entries only)" .-> STORE

    %% turn flow
    HIST --> BUILD --> STREAM --> PERM
    PERM --> FIC --> RETRY --> MW --> PROV --> MODEL
    MODEL --> TOOLCALL
    TOOLCALL -- yes --> INVOKE --> MODEL
    TOOLCALL -- "no (final text)" --> STREAM
    STREAM --> RECON --> DECIDE
    DECIDE -- yes --> BUILD
    DECIDE -- no --> DONE["break → persist + TurnEndEvent"]

    classDef durable fill:#1f2933,stroke:#7b8794,color:#e4e7eb
    classDef mem fill:#243b53,stroke:#4a90d9,color:#e4e7eb
    classDef runtime fill:#3d2b1f,stroke:#c08457,color:#f5e6d3
    class STORE durable
    class HIST,BUILD,STREAM,RECON mem
    class MODEL runtime
