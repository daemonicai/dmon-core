<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="http://reactiveui.net"
        xmlns:local="clr-namespace:Dmon.Desktop"
        mc:Ignorable="d"
        x:Class="Dmon.Desktop.MainWindow"
        Title="dmon"
        Width="1024"
        Height="768"
        Background="#0a0a0a">

  <!-- Boot gate: BootPanel while Booting/Faulted; ConversationArea when Ready. -->
  <Grid>

    <!-- Boot / fault state panel -->
    <StackPanel x:Name="BootPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <TextBlock x:Name="BootLabel"
                 Text="booting..."
                 FontFamily="Courier New, Monospace"
                 FontSize="16"
                 Foreground="#33ff33"
                 HorizontalAlignment="Center" />
    </StackPanel>

    <!-- Conversation area — hidden until Ready; hosts the routed view stack. -->
    <Grid x:Name="ConversationArea"
          IsVisible="False"
          RowDefinitions="Auto,*">

      <!-- Thin top bar with reload affordance. Hidden with ConversationArea (child inherits). -->
      <Border Grid.Row="0"
              Background="#0a0a0a"
              BorderBrush="#1a3a1a"
              BorderThickness="0,0,0,1"
              Padding="8,4">
        <!-- HotKey routes Ctrl+R to this button's Command; CanExecute=!IsStreaming auto-disables. -->
        <Button x:Name="ReloadButton"
                Content="⟳ reload"
                HotKey="Ctrl+R"
                FontFamily="Courier New, Monospace"
                FontSize="11"
                Foreground="#33ff33"
                Background="Transparent"
                BorderBrush="#33ff33"
                BorderThickness="1"
                Padding="6,2"
                HorizontalAlignment="Right"
                Cursor="Hand" />
      </Border>

      <!-- Routed view stack fills remaining height. -->
      <rxui:RoutedViewHost x:Name="ConversationHost"
                           Grid.Row="1" />
    </Grid>

  </Grid>

</Window>
