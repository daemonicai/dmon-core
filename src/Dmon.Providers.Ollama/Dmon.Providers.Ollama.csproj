<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <AssemblyName>Dmon.Providers.Ollama</AssemblyName>
    <IsPackable>true</IsPackable>
    <PackageId>Dmon.Providers.Ollama</PackageId>
    <MinVerTagPrefix>sdk-</MinVerTagPrefix>
    <Description>Ollama provider extension for the dmon coding agent. Exposes UseOllama() in the Dmon.Hosting namespace.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OllamaSharp" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Dmon.Abstractions/Dmon.Abstractions.csproj" />
  </ItemGroup>

</Project>
