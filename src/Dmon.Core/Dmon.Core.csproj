<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>dmoncore</AssemblyName>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);NU1901</NoWarn>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>dotnet-Dmon.Core-235116ed-4152-4f15-a7a2-f92f60df0333</UserSecretsId>

    <IsPackable>true</IsPackable>
    <!-- Independent version line for the dmoncore agent core -->
    <MinVerTagPrefix>core-</MinVerTagPrefix>
    <Description>The dmoncore agent core — a .NET coding agent published as a runnable framework-dependent closure. Acquired and managed at runtime by the dmon host tool; not intended as a library reference.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!--
      Root-closure layout: the package carries the full framework-dependent publish output
      at the archive root so Dmon.Runtime can resolve dmoncore.dll via
      Path.Combine(expandedPath, "dmoncore.dll") and launch it via dotnet exec.
      This is intentional per ADR-011 D2/D4 — NOT a library package.

      IncludeBuildOutput=false suppresses the default lib/net10.0 entry so that
      only the explicit publish closure (added by _AddPublishClosureToPackage below)
      appears in the package.

      NU5100: assembly outside lib/tfm — expected; closure sits at root.
      NU5128: no matching lib/tfm folder — expected; this is a runnable closure, not a lib.

      IncludeSymbols=false: a symbols package (.snupkg) is not meaningful for a runnable
      closure — it would contain no content and fail with NU5017. The publish closure
      does carry PDBs inline, which is sufficient for crash diagnostics.
    -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IncludeSymbols>false</IncludeSymbols>
    <!-- Suppress pack warnings that are expected for the deliberate root-closure layout. -->
    <NoWarn>$(NoWarn);NU5100;NU5128</NoWarn>

    <!-- Suppress dependency generation: the publish closure carries every assembly;
         consumers never restore this package as a library dependency. -->
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Dotnet.Script.Core" Version="2.0.0" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />
    <!-- M.E.AI pinned to the abstractions version Anthropic 12.x targets; re-validate when bumping Anthropic. -->
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.5.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.8" />
    <PackageReference Include="NetEscapades.Configuration.Yaml" Version="3.1.0" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.3" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.3" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" Version="1.15.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dmon.Abstractions\Dmon.Abstractions.csproj" />
    <ProjectReference Include="..\Dmon.Protocol\Dmon.Protocol.csproj" />
    <ProjectReference Include="..\Dmon.BuiltinTools\Dmon.BuiltinTools.csproj" />
    <ProjectReference Include="..\Dmon.Extensions\Dmon.Extensions.csproj" />
    <ProjectReference Include="..\Dmon.Providers\Dmon.Providers.csproj" />
    <ProjectReference Include="..\Dmon.Providers.Ollama\Dmon.Providers.Ollama.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <!-- Suppress content/ + contentFiles/ injection. The Worker SDK auto-includes appsettings*.json
         as Content items (Pack=true), which adds them under content/ and contentFiles/any/net10.0/.
         Those paths are inert for a runnable closure; the root copies come from the publish closure
         target (_AddPublishClosureToPackage). Pack=false here drops the duplicate content-pipe entries. -->
    <Content Update="appsettings*.json" Pack="false" />
  </ItemGroup>

  <!--
    Publish the project framework-dependently into a staging directory, then add
    every file from that directory to the package at the root (PackagePath="").
    This gives Dmon.Runtime's NuGetCoreAcquisitionSource the layout it expects:
    <cache>/dmoncore/<version>/dmoncore.dll (and the full publish closure alongside it),
    so it can be launched via `dotnet exec`.

    TargetsForTfmSpecificContentInPackage registers _AddPublishClosureToPackage as
    a target the SDK pack pipeline calls when gathering per-tfm package content.
    Items added to TfmSpecificPackageFile inside that target are picked up by the pack.
  -->
  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_AddPublishClosureToPackage</TargetsForTfmSpecificContentInPackage>
    <_PublishClosureStageDir>$(BaseIntermediateOutputPath)publish-closure/</_PublishClosureStageDir>
  </PropertyGroup>

  <Target Name="_AddPublishClosureToPackage">
    <!-- Framework-dependent publish into the staging dir (no apphost, no RID). -->
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Publish"
             Properties="Configuration=$(Configuration);PublishDir=$(_PublishClosureStageDir);PublishProtocol=FileSystem;SelfContained=false;RuntimeIdentifier=;UseAppHost=false" />

    <!-- Enumerate every file in the staging dir (flat — no subdirectories for the root closure). -->
    <ItemGroup>
      <_ClosureFiles Include="$(_PublishClosureStageDir)*" />
    </ItemGroup>

    <!-- Add flat files to the package root (PackagePath=""). -->
    <ItemGroup>
      <TfmSpecificPackageFile Include="@(_ClosureFiles)"
                              PackagePath="" />
    </ItemGroup>

    <!-- Recurse into locale subdirs (e.g. cs/, de/ resource satellites) preserving relative path. -->
    <ItemGroup>
      <_ClosureSubdirs Include="$(_PublishClosureStageDir)**\*"
                       Exclude="$(_PublishClosureStageDir)*" />
    </ItemGroup>
    <ItemGroup>
      <TfmSpecificPackageFile Include="@(_ClosureSubdirs)"
                              PackagePath="%(RecursiveDir)" />
    </ItemGroup>
  </Target>

</Project>
