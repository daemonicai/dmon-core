<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Library</OutputType>
    <GenerateRuntimeConfigurationFiles>false</GenerateRuntimeConfigurationFiles>
    <AssemblyName>Dmon.Core</AssemblyName>
    <PackageId>dmoncore</PackageId>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);NU1901</NoWarn>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>dotnet-Dmon.Core-235116ed-4152-4f15-a7a2-f92f60df0333</UserSecretsId>

    <IsPackable>true</IsPackable>
    <!-- Independent version line for the dmoncore agent core -->
    <MinVerTagPrefix>core-</MinVerTagPrefix>
    <Description>The dmoncore agent core — a .NET library package referenced by a Dmon.cs composition-root file via #:package dmoncore. Exposes Dmon.Hosting.DmonHost for building and running the agent.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />
    <!-- M.E.AI pinned to the abstractions version Anthropic 12.x targets; re-validate when bumping Anthropic. -->
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.5.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.8" />
    <PackageReference Include="NetEscapades.Configuration.Yaml" Version="3.1.0" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.3" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.3" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" Version="1.15.1" />
    <!-- External deps of bundled impl projects (Dmon.Providers, Dmon.Providers.Ollama, Dmon.BuiltinTools).
         Their DLLs are bundled into lib/net10.0/ and do not declare their own package dependencies,
         so we declare them here so the consumer's restore closure is complete. -->
    <PackageReference Include="Anthropic" Version="12.24.1" />
    <PackageReference Include="GeminiDotnet.Extensions.AI" Version="0.25.0" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" Version="10.5.1" />
    <PackageReference Include="OllamaSharp" Version="5.4.25" />
  </ItemGroup>

  <ItemGroup>
    <!-- Contract packages: remain as normal refs so they appear as package dependencies in the nuspec. -->
    <ProjectReference Include="..\Dmon.Abstractions\Dmon.Abstractions.csproj" />
    <ProjectReference Include="..\Dmon.Protocol\Dmon.Protocol.csproj" />
    <!-- Impl projects: bundled into lib/net10.0/ — PrivateAssets="all" suppresses them as nuspec deps. -->
    <ProjectReference Include="..\Dmon.BuiltinTools\Dmon.BuiltinTools.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\Dmon.Providers\Dmon.Providers.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\Dmon.Providers.Ollama\Dmon.Providers.Ollama.csproj" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <!-- Suppress content/ + contentFiles/ injection from the Worker SDK auto-include of appsettings*.json. -->
    <Content Update="appsettings*.json" Pack="false" />
  </ItemGroup>

  <!--
    Bundle impl project DLLs (Dmon.BuiltinTools, Dmon.Providers, Dmon.Providers.Ollama) into lib/net10.0/.
    TargetsForTfmSpecificBuildOutput registers the target so the SDK pack pipeline picks up the extra items.
    We filter ReferenceCopyLocalPaths to only the three impl assemblies by filename to avoid accidentally
    bundling the contract packages (Protocol/Abstractions) which are proper package dependencies.
  -->
  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyImplDepsToPackage</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>

  <Target Name="CopyImplDepsToPackage" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths)"
                            Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference'
                                       And (
                                         $([System.String]::Copy('%(Filename)').Equals('Dmon.BuiltinTools'))
                                         Or $([System.String]::Copy('%(Filename)').Equals('Dmon.Providers'))
                                         Or $([System.String]::Copy('%(Filename)').Equals('Dmon.Providers.Ollama'))
                                       )" />
    </ItemGroup>
  </Target>

</Project>
