<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>dmon</AssemblyName>
    <RootNamespace>Dmon.Terminal</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>dmon</ToolCommandName>
    <!-- Independent version line for the dmon console host -->
    <MinVerTagPrefix>dmon-</MinVerTagPrefix>
    <Description>The dmon console host — a .NET global tool that launches and communicates with the dmoncore agent over JSONL/stdio.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" Version="1.*" />
    <PackageReference Include="Dcli" Version="0.2.0-rc.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dmon.Protocol\Dmon.Protocol.csproj" />
    <ProjectReference Include="..\Dmon.Runtime\Dmon.Runtime.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
