<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>dmon</AssemblyName>
    <RootNamespace>Dmon.Terminal</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" Version="1.*" />
    <PackageReference Include="Dcli" Version="0.2.0-rc.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dmon.Protocol\Dmon.Protocol.csproj" />
    <ProjectReference Include="..\Dmon.Runtime\Dmon.Runtime.csproj" />
  </ItemGroup>

</Project>
