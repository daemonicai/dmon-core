<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>dmon</AssemblyName>
    <RootNamespace>Dmon.Terminal</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" Version="1.*" />
    <PackageReference Include="Spectre.Console" Version="0.55.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dmon.Protocol\Dmon.Protocol.csproj" />
    <ProjectReference Include="..\Dmon.Abstractions\Dmon.Abstractions.csproj" />
    <ProjectReference Include="..\Dmon.Providers\Dmon.Providers.csproj" />
    <ProjectReference Include="..\Dmon.Providers.Ollama\Dmon.Providers.Ollama.csproj" />
    <ProjectReference Include="..\..\..\dcli\src\Dcli\Dcli.csproj" />
  </ItemGroup>

</Project>
