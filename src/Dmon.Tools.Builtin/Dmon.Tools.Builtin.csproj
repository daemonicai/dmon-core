<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <AssemblyName>Dmon.Tools.Builtin</AssemblyName>
    <IsPackable>true</IsPackable>
    <PackageId>Dmon.Tools.Builtin</PackageId>
    <MinVerTagPrefix>sdk-</MinVerTagPrefix>
    <Description>Built-in tools (read_file, write_file, edit_file, glob, fetch, bash) for the dmon coding agent. Exposes AddBuiltinTools() in the Dmon.Hosting namespace.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- M.E.AI pinned to the abstractions version Anthropic 12.x targets; re-validate when bumping Anthropic. -->
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.5.1" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dmon.Abstractions\Dmon.Abstractions.csproj" />
    <ProjectReference Include="..\Dmon.Protocol\Dmon.Protocol.csproj" />
  </ItemGroup>

</Project>
