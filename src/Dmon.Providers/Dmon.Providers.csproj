<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- M.E.AI pinned to the abstractions version Anthropic 12.x targets; re-validate when bumping Anthropic. -->
    <PackageReference Include="Anthropic" Version="12.24.1" />
    <PackageReference Include="GeminiDotnet.Extensions.AI" Version="0.25.0" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" Version="10.5.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dmon.Abstractions\Dmon.Abstractions.csproj" />
  </ItemGroup>

</Project>
