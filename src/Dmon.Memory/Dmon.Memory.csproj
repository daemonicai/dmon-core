    <PackageReference Include="LLamaSharp.Backend.Cpu" Version="0.27.0" />
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.5.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Dmon.Abstractions\Dmon.Abstractions.csproj" />
    <ProjectReference Include="..\Dmon.Core\Dmon.Core.csproj" />
  </ItemGroup>
</Project>
