<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Local feed directory populated by scripts/smoke-sdk.sh.
      All three SDK packages (Dmon.Protocol, Dmon.Abstractions, Dmon.Extensions) must be
      packed there before building this project.
    -->
    <add key="local-dmon-feed" value="../../.pack-out" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
