<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Local feed populated by scripts/pack-core.sh.
      dmoncore 0.2.0, Dmon.SampleExtension 0.2.0, and contract packages must be
      packed there before building this project.
    -->
    <add key="local-dmon-feed" value="../../.pack-out" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
