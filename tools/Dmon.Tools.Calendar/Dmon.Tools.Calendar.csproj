<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <AssemblyName>Dmon.Tools.Calendar</AssemblyName>
    <IsPackable>true</IsPackable>
    <PackageId>Dmon.Tools.Calendar</PackageId>
    <MinVerTagPrefix>sdk-</MinVerTagPrefix>
    <Description>Calendar tools (lookup_calendar, list_upcoming_events) for the dmon coding agent. Register with builder.AddCalendarAbilities() from the Dmon.Hosting namespace.</Description>
    <PackageTags>dmon;calendar;tools;agent</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\core\Dmon.Abstractions\Dmon.Abstractions.csproj" />
    <ProjectReference Include="..\..\core\Dmon.Protocol\Dmon.Protocol.csproj" />
  </ItemGroup>

</Project>
